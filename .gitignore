## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.user-r
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPS/
[Release]/
[Release]PS/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bin]/
[Ob]j/
[Log]/
[Logs]/
bin/
obj/

# Visual Studio 2015/2017 cache directory
.vs/
# Generated user content
ChromeTrace.log

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Selenium WebDriver log files
chromedriver.log
geckodriver.log

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-workspace
.history/

# JetBrains Rider
.idea/
*.sln.iml

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Net Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
mini-profiler resources

# Server Usages
ReSharper*/
_ReSharper*/

# DotCover
*.dotCover

# AxoCover
.axoCover/*
_axoCover/*

# Coverlet
coverlet/

# Visual Studio Image Optimizer
artifacts/

# Nuget
packages/
*.nupkg
# NuGet Packager local backup
*.nuget.backup

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web Workbench (Stylus decompilation)
.sass-cache/

# Installshield output folder
Express/

# DocFX is a API documentation generator
_site/

# C++ project database analyze common folder
ipch/
*.aps
*.ncb
*.opendb
*.sdf
*.cache
*.ilk
*.log
*.sbr
*.obj
*.pch
*.pdb
*.ipdb
*.iobj

# Client-side Web folders
node_modules/
bower_components/

# Syncthing files
.syncthing.*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might be created on a Mac OS X Volume
.DocumentRevisions-V100
.SyncID
.SyncRules
.SyncRules.local
.SyncRules.local~
.SyncRules.shared
.SyncRules.shared~
.SyncRules.shared.local
.SyncRules.shared.local~
.SyncRules.shared.local.bak
.SyncID.local
.SyncID.local~
.SyncID.shared
.SyncID.shared~
.SyncID.shared.local
.SyncID.shared.local~
.SyncID.shared.local.bak
.SyncState
.SyncState.local
.SyncState.local~
.SyncState.shared
.SyncState.shared~
.SyncState.shared.local
.SyncState.shared.local~
.SyncState.shared.local.bak

# Directory crash logs
.DirectoryCrash

# Files that might be created on a WebDAV share
.apdisk
